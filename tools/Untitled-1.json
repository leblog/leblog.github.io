内。\n识别主题：用一句话概括商品主体（如“户外登山背包正面展示”），识别不出则返回“无法识别”。\n提取标签：生成3-10个适合搜索的标签，涵盖品类、场景、材质、风格、颜色等维度。\nJSON输出：最后输出标准JSON格式，包含“主题描述”和“语义标签”。","deployed_link":"https://code.coze.cn/p/7584733203986974783","detail_link":"https://code.coze.cn/p/7584733203986974783","display_detail":true,"enable_cross_space_copy":true,"icon_url":"https://coze-coding-project.tos.coze.site/homepage/%E7%94%B5%E5%95%86%E5%9B%BE%E8%87%AA%E5%8A%A8%E6%89%93%E6%A0%87%E5%B7%A5%E4%BD%9C%E6%B5%81.png?sign=4902632633-97c70b4f64-0-64aac7317ae3ea2734559fc550f1fbdc5eb03d6e3ea323021da22cee2541993e","project_info":{"create_time":"1765962445507","creator_id":"3256101478336556","description":"电商图自动打标工作流：上传商品图自动预处理、生成主题描述和3-10个多维度标签，输出标准JSON。","icon_uri":"gen_project_icon/2025-12-17/7584733203986974783_1765962464.png","icon_url":"https://coze-coding-project.tos.coze.site/gen_project_icon/2025-12-17/7584733203986974783_1765962464.png?sign=4902632630-1e2c97e8ac-0-bbee91f68ab41851d5b37f7015609f4c06833a98688cebe528b4c2f3a7db070a","name":"电商图自动打标工作流","project_id":"7584733203986974783","project_settings":{"agent_tools":{"enable_image_gen":false,"enable_web_search":true},"model_setting":{"model_name":""},"project_mode":0,"skill_setting":{"filter_types":[],"removed_skill_ids":[],"skills":[{"is_preload":false,"skill_id":"7602481502416322579"},{"is_preload":false,"skill_id":"7602481502693113910"},{"is_preload":false,"skill_id":"7602481502693244982"},{"is_preload":false,"skill_id":"7602482238973886500"},{"is_preload":false,"skill_id":"7602482442187882532"},{"is_preload":false,"skill_id":"7602481839030583332"},{"is_preload":false,"skill_id":"7611454403656040490"},{"is_preload":false,"skill_id":"7611453474399731748"},{"is_preload":false,"skill_id":"7605902296211292196"},{"is_preload":false,"skill_id":"7603358536063533062"},{"is_preload":false,"skill_id":"7626675160883396662"},{"is_preload":false,"skill_id":"7602478014626119722"},{"is_preload":false,"skill_id":"7602477556083736612"},{"is_preload":false,"skill_id":"7602478796135579711"},{"is_preload":false,"skill_id":"7602474304034308159"},{"is_preload":false,"skill_id":"7602479193770835987"},{"is_preload":false,"skill_id":"7602479516123938858"},{"is_preload":false,"skill_id":"7602480026541408297"},{"is_preload":false,"skill_id":"7602480711085408299"},{"is_preload":false,"skill_id":"7602481198144700435"}]},"wizards":{"design":false}},"project_type":2,"space_id":"7580309300548173875","update_time":"1778308400464"},"project_type":2},{"author_name":"扣子官方","case_id":"8","case_name":"新品上市全渠道营销工作流","case_query":"请为我启动“新品上市全渠道营销”工作流。当我上传一张产品白底图后，先深度解码其材质细节与设计语言，随即并行触发三条高级图文创作专线：\n1、针对小红书，请打造“生活仪式感”。先撰写一篇情绪价值拉满的KOC种草文案，后生图将产品完美融合进温馨的家居场景（如清晨阳光洒落的窗台），营造治愈氛围。\n2、针对LinkedIn，请切换至“精英商务风”。先产出强调效率与参数的专业英文Post，再配合冷峻高级灰调的现代办公室背景生图，突显产品的工业质感。\n3、针对邮件营销，请聚焦“销售转化”。生成带有FOMO（错失恐惧）心理的限时大促文案，后并制作一张背景纯净、含高对比度“Shop Now”按钮的Banner图。\n最后，将这三套风格迥异的图文素材打包成可视化良好的markdwon，一次性交付给我。","deployed_link":"https://code.coze.cn/p/7594807962091257907","detail_link":"https://code.coze.cn/p/7594807962091257907","display_detail":true,"enable_cross_space_copy":true,"icon_url":"https://coze-coding-project.tos.coze.site/homepage/%E6%96%B0%E5%93%81%E4%B8%8A%E5%B8%82%E5%85%A8%E6%B8%A0%E9%81%93%E8%90%A5%E9%94%80%E5%B7%A5%E4%BD%9C%E6%B5%81.png?sign=4902632634-92acad4792-0-c9fbb6294c5cd2b706ada27d3b0b6b7889678a7420aed69f33338456c360ba82","project_info":{"create_time":"1768306459076","creator_id":"3256101478336556","description":"新品上市全渠道营销工作流：上传白底图自动解码，触发小红书/LinkedIn/邮件图文创作并打包交付。","icon_uri":"gen_project_icon/2026-01-13/7594807962091257907_1768306475.png","icon_url":"https://coze-coding-project.tos.coze.site/gen_project_icon/2026-01-13/7594807962091257907_1768306475.png?sign=4902632630-b4e5c86176-0-f9b704f62da85b58ef5da142f16e33dff07ccf41988b3e33c74d77be9c3c6988","name":"新品上市全渠道营销工作流","project_id":"7594807962091257907","project_settings":{"agent_tools":{"enable_image_gen":false,"enable_web_search":true},"project_mode":0,"skill_setting":{"filter_types":[],"removed_skill_ids":[],"skills":[{"is_preload":false,"skill_id":"7602481502416322579"},{"is_preload":false,"skill_id":"7602481502693113910"},{"is_preload":false,"skill_id":"7602481502693244982"},{"is_preload":false,"skill_id":"7602482238973886500"},{"is_preload":false,"skill_id":"7602482442187882532"},{"is_preload":false,"skill_id":"7602481839030583332"},{"is_preload":false,"skill_id":"7611454403656040490"},{"is_preload":false,"skill_id":"7611453474399731748"},{"is_preload":false,"skill_id":"7605902296211292196"},{"is_preload":false,"skill_id":"7603358536063533062"},{"is_preload":false,"skill_id":"7626675160883396662"},{"is_preload":false,"skill_id":"7602478014626119722"},{"is_preload":false,"skill_id":"7602477556083736612"},{"is_preload":false,"skill_id":"7602478796135579711"},{"is_preload":false,"skill_id":"7602474304034308159"},{"is_preload":false,"skill_id":"7602479193770835987"},{"is_preload":false,"skill_id":"7602479516123938858"},{"is_preload":false,"skill_id":"7602480026541408297"},{"is_preload":false,"skill_id":"7602480711085408299"},{"is_preload":false,"skill_id":"7602481198144700435"}]},"wizards":{"design":false}},"project_type":2,"space_id":"7594776728204017674","update_time":"1768306476347"},"project_type":2},{"author_name":"扣子官方","case_id":"9","case_name":"行业热点捕捉工作流","case_query":"帮我设计一套行业热点捕捉工作流。输入行业关键词（比如“新能源电池”）后，请按以下逻辑自动出内容：\n第一步：找新闻并定调，搜集全网热点。先看一眼今天有没有那个值得头版头条的“超级大瓜”。\n第二步：制定内容策略和生3-5张图（根据定调结果）\n如果有大瓜（重磅模式）：先分析解读热点深挖这一件事，讲透背后的逻辑。然后根据热点解读，生成一张高质感的电影级海报和其他几张解读配图，画面要只突出这一个主角，让人一眼被震撼和抓住眼球。\n如果是平时（日常模式）：我们就做高效盘点。把今天最有价值的3-5个消息汇总好。生成的图片根据消息配几张连环画，或者拼图形式，主打一个“信息量丰富，一图看懂”。\n第三步：交付图片和文案成品，不管是哪种模式，图片都要生成 3:4 的竖图（方便发小红书），文案要配好标题，一起返回给我。","deployed_link":"https://code.coze.cn/p/7594808325909348379","detail_link":"https://code.coze.cn/p/7594808325909348379","display_detail":true,"enable_cross_space_copy":true,"icon_url":"https://coze-coding-project.tos.coze.site/homepage/%E8%A1%8C%E4%B8%9A%E7%83%AD%E7%82%B9%E6%8D%95%E6%8D%89%E5%B7%A5%E4%BD%9C%E6%B5%81.png?sign=4902632634-a572a39ca7-0-a5e7fe599dc97a37fe